# Stilla Escalation Agent - environment template
# The agent runs fully WITHOUT any of these set (deterministic offline fallback),
# so a reviewer can clone and run with zero secrets.

# Optional: enables real Anthropic API calls instead of the offline fallback.
ANTHROPIC_API_KEY=

# Optional guardrail tuning (defaults shown):
STILLA_TOKEN_BUDGET=50000
STILLA_AGENT_DISABLED=false
